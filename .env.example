# FitMate AI local/staging environment template.
# Do not commit real secrets in .env files.

FITMATE_APP_NAME="FitMate AI API"
FITMATE_ENV=development
FITMATE_API_VERSION=v1

# PostgreSQL
DATABASE_URL=postgresql+psycopg://fitmate:fitmate@localhost:5432/fitmate

# Backend tests run destructive table cleanup only when FITMATE_ENV is local/test
# and DATABASE_URL points to an approved localhost FitMate database.
# Example focused test run:
# FITMATE_ENV=local
# DATABASE_URL=postgresql+psycopg://fitmate:fitmate@localhost:5432/fitmate

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage
OBJECT_STORAGE_DRIVER=memory
OBJECT_STORAGE_BUCKET=fitmate-food-photos
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_KEY_PREFIX=food-photos

# AI providers
XIAOMI_MODEL_NAME=mimo-v2-omni
XIAOMI_API_KEY=
XIAOMI_BASE_URL=
QWEN_MODEL_NAME=qwen3-vl-plus
QWEN_API_KEY=
QWEN_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI extraction feature flags. Keep false for deterministic local smoke tests;
# turn on only when provider keys are configured and you want live AI extraction.
FILE_AI_EXTRACTION_ENABLED=false
WORKOUT_AI_ANALYSIS_ENABLED=false
TEXT_FOOD_AI_ANALYSIS_ENABLED=false
CHAT_AI_REPLY_ENABLED=false

# Auth/admin
# Production startup fails if these are left as local defaults or shorter than
# 32 characters.
AUTH_SECRET_KEY=replace-with-a-long-random-secret
ADMIN_SECRET=replace-with-a-long-random-admin-secret
ACCESS_TOKEN_MINUTES=10080

# App Store / subscription validation
APP_STORE_BUNDLE_ID=
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
APP_STORE_PRIVATE_KEY_PATH=
APP_STORE_SHARED_SECRET=

# Mobile app runtime
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_USE_MOCK_API=true
