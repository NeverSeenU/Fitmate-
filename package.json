{
  "name": "fitmate-ai-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node .test-build/tests/runLogicTests.js",
    "smoke:mobile": "tsc -p tsconfig.test.json && node .test-build/tests/runMobileSmoke.js",
    "smoke:file-insight-live": "tsc -p tsconfig.test.json && node .test-build/tests/runLiveFileInsightSmoke.js",
    "smoke:file-insight-ai": "tsc -p tsconfig.test.json && node .test-build/tests/runLiveFileInsightSmoke.js --require-ai-metadata"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
